# ─────────────────────────────────────────────────────
# Variables d'environnement Klaro
# Copier ce fichier en `.env.local` et remplir les valeurs.
# Ne JAMAIS committer .env.local (déjà dans .gitignore).
# ─────────────────────────────────────────────────────

# Supabase — Settings → API
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Clé "publishable" (alias anon) — exposable côté client
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxx

# Clé "secret" (alias service_role) — JAMAIS exposée côté client
# Utilisée uniquement par les Server Components / Route Handlers / scripts admin
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx
